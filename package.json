{
  "name": "linter-stylelint-pulsar",
  "version": "4.6.0",
  "private": true,
  "description": "A plugin for Atom/Pulsar Linter providing an interface to stylelint.",
  "main": "lib/index.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexrudd2/linter-stylelint"
  },
  "engines": {
    "atom": ">=1.7.0 <2.0.0"
  },
  "scripts": {
    "test": "APM_TEST_PACKAGES='linter-stylelint language-postcss' pulsar --test spec",
    "lint": "biome lint .",
    "prepare": "husky install"
  },
  "keywords": [
    "css",
    "lint",
    "postcss",
    "stylelint"
  ],
  "author": {
    "name": "1000ch",
    "email": "shogo.sensui@gmail.com",
    "url": "http://github.com/1000ch"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexrudd2/linter-stylelint/issues"
  },
  "configSchema": {
    "useStandard": {
      "title": "Use standard",
      "description": "Use the stylelint-config-standard lint configuration when no other configuration is found. Disables the \"Disable when no config\" option.",
      "type": "boolean",
      "default": false
    },
    "disableWhenNoConfig": {
      "title": "Disable when no config is found",
      "description": "You can find the list of supported formats in the [stylelint docs](https://stylelint.io/user-guide/configuration/#loading-the-configuration-object).",
      "type": "boolean",
      "default": true
    },
    "showIgnored": {
      "title": "Show message when a file is ignored",
      "type": "boolean",
      "default": false
    },
    "fixOnSave": {
      "description": "Automatically attempt to fix errors using stylelint --fix flag (experimental)",
      "title": "Attempt to fix styles on save",
      "type": "boolean",
      "default": false
    }
  },
  "homepage": "https://github.com/alexrudd2/linter-stylelint#readme",
  "dependencies": {
    "@types/jasmine": "^6.0.0",
    "assign-deep": "1.0.1",
    "atom-linter": "10.0.0",
    "postcss-less": "^6.0.0",
    "postcss-scss": "4.0.9",
    "resolve": "1.22.12",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "sugarss": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "atom-jasmine2-test-runner": "^2.99.1",
    "husky": "9.1.7",
    "rimraf": "^6.0.0",
    "semantic-release": "25.0.3"
  },
  "package-deps": [
    {
      "name": "linter",
      "minimumVersion": "3.4.0"
    }
  ],
  "providedServices": {
    "linter": {
      "versions": {
        "2.0.0": "provideLinter"
      }
    }
  },
  "release": {
    "extends": "@semantic-release/apm-config"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "renovate": {
    "extends": [
      "config:recommended"
    ],
    "packageRules": [
      {
        "matchDepTypes": [
          "devDependencies"
        ],
        "automerge": true
      }
    ]
  },
  "atomTestRunner": "atom-jasmine2-test-runner"
}
